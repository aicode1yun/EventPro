<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Ticket"
             xmlns:conv="clr-namespace:Ticket.Converters"
             xmlns:uxd="clr-namespace:UXDivers.Popups.Maui.Controls;assembly=UXDivers.Popups.Maui"
             x:Class="Ticket.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
                <uxd:DarkTheme />
                <uxd:PopupStyles />
            </ResourceDictionary.MergedDictionaries>

            <!-- Popup icon overrides (use our Font Awesome glyphs) -->
            <x:String x:Key="IconsFontFamily">FAS</x:String>
            <x:String x:Key="AppFontFamily">OpenSans-Regular</x:String>
            <x:String x:Key="AppSemiBoldFamily">OpenSans-Semibold</x:String>
            <x:String x:Key="UXDPopupsCloseIconButton">&#xf00d;</x:String>
            <x:String x:Key="UXDPopupsCheckCircleIconButton">&#xf00c;</x:String>

            <conv:IsNotNullConverter x:Key="IsNotNullConverter" />
            <conv:IsNullConverter x:Key="IsNullConverter" />
            <conv:BoolToColorConverter x:Key="BoolToColorConverter" />
            <conv:CheckInStatusConverter x:Key="CheckInStatusConverter" />
            <conv:DateTimeFormatConverter x:Key="DateTimeFormatConverter" />
            <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
            <conv:BoolToColorConverter x:Key="BoolToFilterBg" TrueValue="{StaticResource Primary}" FalseValue="{StaticResource PrimaryLight}" />
            <conv:BoolToColorConverter x:Key="BoolToFilterText" TrueValue="White" FalseValue="{StaticResource Primary}" />
            <conv:BoolToOpacityConverter x:Key="BoolToTorchOpactiy" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
