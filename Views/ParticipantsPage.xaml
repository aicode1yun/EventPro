<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Ticket.ViewModels"
             xmlns:components="clr-namespace:Ticket.Components"
             xmlns:models="clr-namespace:Ticket.Models"
             x:Class="Ticket.Views.ParticipantsPage"
             x:DataType="vm:ParticipantsViewModel"
             Title="Attendees"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource DarkPageBackground}}">

    <Grid RowDefinitions="Auto,Auto,*">
        <!-- Search Header -->
        <Border Style="{StaticResource Card}"
                Margin="20,16,20,0"
                Padding="8,0"
                StrokeShape="RoundRectangle 14">
            <SearchBar Placeholder="Search by name, code, or phone..."
                       Text="{Binding SearchText}"
                       BackgroundColor="Transparent"
                       CancelButtonColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource Secondary}}" />
        </Border>

        <!-- Filter Chips -->
        <ScrollView Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="20,12,20,8"
                    HorizontalScrollBarVisibility="Never">
            <HorizontalStackLayout Spacing="8"
                                   BindableLayout.ItemsSource="{Binding FilterChips}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="models:FilterChip">
                        <Border BackgroundColor="{Binding IsSelected, Converter={StaticResource BoolToFilterBg}}"
                                StrokeShape="RoundRectangle 20"
                                StrokeThickness="0"
                                Padding="16,8"
                                HeightRequest="36">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ParticipantsViewModel}}, Path=SelectFilterCommand}"
                                                      CommandParameter="{Binding Text}" />
                            </Border.GestureRecognizers>
                            <Label Text="{Binding Text}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="{Binding IsSelected, Converter={StaticResource BoolToFilterText}}"
                                   VerticalOptions="Center" />
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </HorizontalStackLayout>
        </ScrollView>

        <!-- Participant List -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Attendees}"
                        Margin="20,4,20,0">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Attendee">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Delete"
                                           BackgroundColor="{StaticResource Danger}"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ParticipantsViewModel}}, Path=DeleteAttendeeCommand}"
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ParticipantsViewModel}}, Path=ViewDetailCommand}"
                                                  CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <components:AttendeeCard Attendee="{Binding .}" />
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <!-- Empty State -->
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Spacing="16"
                                     Padding="40">
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceSecondary}, Dark={StaticResource DarkSurfaceSecondary}}"
                            StrokeShape="RoundRectangle 20"
                            StrokeThickness="0"
                            WidthRequest="80" HeightRequest="80"
                            HorizontalOptions="Center">
                        <Label Text="&#xf007;"
                               FontFamily="FAS"
                               FontSize="32"
                               TextColor="{AppThemeBinding Light={StaticResource TextTertiary}, Dark={StaticResource DarkTextTertiary}}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                    <Label Text="No participants yet"
                           Style="{StaticResource Headline}"
                           HorizontalOptions="Center" />
                    <Label Text="Register attendees to get started"
                           Style="{StaticResource BodySmall}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>

</ContentPage>
