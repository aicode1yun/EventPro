<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Ticket.ViewModels"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.Maui.Controls"
             x:Class="Ticket.Views.ScannerPage"
             x:DataType="vm:ScannerViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource DarkPageBackground}}">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="24,20,24,32">

            <!-- Header -->
            <Label Text="Scan Ticket"
                   Style="{StaticResource DisplayMedium}"
                   Margin="0,0,0,4" />
            <Label Text="Point the camera at the attendee&#x2019;s QR code"
                   Style="{StaticResource BodySmall}"
                   Margin="0,0,0,24" />

            <!-- Camera area -->
            <Grid HeightRequest="420">
                <zxing:CameraBarcodeReaderView x:Name="BarcodeReader"
                                                IsDetecting="{Binding IsScanning}"
                                                BarcodesDetected="OnBarcodesDetected"
                                                VerticalOptions="Fill"
                                                HorizontalOptions="Fill" />

                <!-- Corner brackets -->
                <Grid HorizontalOptions="Center"
                      VerticalOptions="Center"
                      WidthRequest="230"
                      HeightRequest="230">

                    <BoxView BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource Secondary}}"
                             WidthRequest="24" HeightRequest="3"
                             HorizontalOptions="Start" VerticalOptions="Start" />
                    <BoxView BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource Secondary}}"
                             WidthRequest="3" HeightRequest="24"
                             HorizontalOptions="Start" VerticalOptions="Start" />
                    <BoxView BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource Secondary}}"
                             WidthRequest="24" HeightRequest="3"
                             HorizontalOptions="End" VerticalOptions="Start" />
                    <BoxView BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource Secondary}}"
                             WidthRequest="3" HeightRequest="24"
                             HorizontalOptions="End" VerticalOptions="Start" />
                    <BoxView BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource Secondary}}"
                             WidthRequest="24" HeightRequest="3"
                             HorizontalOptions="Start" VerticalOptions="End" />
                    <BoxView BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource Secondary}}"
                             WidthRequest="3" HeightRequest="24"
                             HorizontalOptions="Start" VerticalOptions="End" />
                    <BoxView BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource Secondary}}"
                             WidthRequest="24" HeightRequest="3"
                             HorizontalOptions="End" VerticalOptions="End" />
                    <BoxView BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource Secondary}}"
                             WidthRequest="3" HeightRequest="24"
                             HorizontalOptions="End" VerticalOptions="End" />

                    <Grid x:Name="ScanLineContainer"
                          HorizontalOptions="Fill"
                          VerticalOptions="Start"
                          HeightRequest="2"
                          Margin="10,0">
                        <BoxView x:Name="ScanLine"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource Secondary}}"
                                 HeightRequest="2"
                                 HorizontalOptions="Fill"
                                 Opacity="0.9" />
                    </Grid>
                </Grid>
            </Grid>

            <!-- Action buttons -->
            <VerticalStackLayout Spacing="16" Margin="0,24,0,0">
                <Border x:Name="TorchButton"
                        BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource DarkSurfaceTertiary}}"
                        StrokeShape="RoundRectangle 9999"
                        StrokeThickness="0"
                        WidthRequest="56" HeightRequest="56"
                        HorizontalOptions="Center"
                        Opacity="{Binding IsTorchOn, Converter={StaticResource BoolToTorchOpactiy}}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTorchClicked" />
                    </Border.GestureRecognizers>
                    <Label Text="&#xf0eb;"
                           FontFamily="FAS"
                           FontSize="22"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource Secondary}}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
                <Label Text="Tap to turn flash on or off"
                       FontSize="12"
                       TextColor="{AppThemeBinding Light={StaticResource TextTertiary}, Dark={StaticResource DarkTextTertiary}}"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
