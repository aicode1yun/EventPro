<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Ticket.ViewModels"
             xmlns:conv="clr-namespace:Ticket.Converters"
             x:Class="Ticket.Views.ParticipantDetailPage"
             x:DataType="vm:ParticipantDetailViewModel"
             Title="Participant"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource DarkPageBackground}}">

    <RefreshView IsRefreshing="{Binding IsBusy}">
        <ScrollView>
            <VerticalStackLayout Spacing="0">

                <!-- Profile Header -->
                <Grid BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark=#1A1B3E}"
                      Padding="20,24,20,36">
                    <VerticalStackLayout Spacing="14" HorizontalOptions="Center">
                        <!-- Avatar -->
                        <Border StrokeShape="RoundRectangle 9999"
                                WidthRequest="96" HeightRequest="96"
                                StrokeThickness="3"
                                Stroke="White"
                                BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryContainer}, Dark={StaticResource DarkSurfaceTertiary}}"
                                HorizontalOptions="Center">
                            <Grid>
                                <Image Source="{Binding AttendeePhoto}"
                                       Aspect="AspectFill"
                                       WidthRequest="96" HeightRequest="96"
                                       IsVisible="{Binding AttendeePhoto, Converter={StaticResource IsNotNullConverter}}" />
                                <Label Text="&#xf007;"
                                       FontFamily="FAS"
                                       FontSize="36"
                                       TextColor="White"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       IsVisible="{Binding AttendeePhoto, Converter={StaticResource IsNullConverter}}" />
                            </Grid>
                        </Border>
                        <Label Text="{Binding Attendee.FullName}"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center" />
                        <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Label Text="{Binding Attendee.TicketCode}"
                                   FontSize="13"
                                   TextColor="#D0D5FF"
                                   FontFamily="FAS" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Grid>

                <!-- Info Card -->
                <Border Style="{StaticResource CardFloating}"
                        Margin="20,-24,20,0"
                        Padding="20">
                    <VerticalStackLayout Spacing="16">
                        <!-- Edit Toggle -->
                        <HorizontalStackLayout Spacing="8" HorizontalOptions="End">
                            <Button Text="Edit"
                                    Style="{StaticResource ButtonGhost}"
                                    Command="{Binding ToggleEditCommand}"
                                    FontSize="13"
                                    Padding="12,6"
                                    HeightRequest="36"
                                    IsVisible="{Binding IsEditing, Converter={StaticResource InverseBoolConverter}}" />
                            <Button Text="Cancel"
                                    Style="{StaticResource ButtonGhost}"
                                    Command="{Binding ToggleEditCommand}"
                                    FontSize="13"
                                    Padding="12,6"
                                    HeightRequest="36"
                                    IsVisible="{Binding IsEditing}" />
                        </HorizontalStackLayout>

                        <!-- View Mode -->
                        <VerticalStackLayout Spacing="14"
                                             IsVisible="{Binding IsEditing, Converter={StaticResource InverseBoolConverter}}">
                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="14" ColumnSpacing="16">
                                <Label Text="Phone" Style="{StaticResource Caption}" />
                                <Label Grid.Column="1" Text="{Binding Attendee.PhoneNumber}" Style="{StaticResource Body}" />

                                <Label Grid.Row="1" Text="Ticket Type" Style="{StaticResource Caption}" />
                                <Label Grid.Row="1" Grid.Column="1" Text="{Binding Attendee.TicketType}" Style="{StaticResource Body}" />

                                <Label Grid.Row="2" Text="Status" Style="{StaticResource Caption}" />
                                <Label Grid.Row="2" Grid.Column="1">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding Attendee.IsCheckedIn, Converter={StaticResource CheckInStatusConverter}}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>

                                <Label Grid.Row="3" Text="Notes" Style="{StaticResource Caption}" />
                                <Label Grid.Row="3" Grid.Column="1" Text="{Binding Attendee.Notes}" Style="{StaticResource BodySmall}" />
                            </Grid>
                        </VerticalStackLayout>

                        <!-- Edit Mode -->
                        <VerticalStackLayout Spacing="14"
                                             IsVisible="{Binding IsEditing}">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Full Name" Style="{StaticResource FormLabel}" />
                                <Border Style="{StaticResource FormField}">
                                    <Entry Text="{Binding EditFullName}" />
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Phone" Style="{StaticResource FormLabel}" />
                                <Border Style="{StaticResource FormField}">
                                    <Entry Text="{Binding EditPhoneNumber}" Keyboard="Telephone" />
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Ticket Type" Style="{StaticResource FormLabel}" />
                                <Border Style="{StaticResource FormField}" Padding="16,0">
                                    <Picker SelectedItem="{Binding EditTicketType}">
                                        <Picker.ItemsSource>
                                            <x:Array Type="{x:Type x:String}">
                                                <x:String>General</x:String>
                                                <x:String>VIP</x:String>
                                                <x:String>Premium</x:String>
                                                <x:String>Early Bird</x:String>
                                                <x:String>Student</x:String>
                                            </x:Array>
                                        </Picker.ItemsSource>
                                    </Picker>
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Notes" Style="{StaticResource FormLabel}" />
                                <Border Style="{StaticResource FormField}" HeightRequest="90" Padding="16,8">
                                    <Editor Text="{Binding EditNotes}" HeightRequest="74" />
                                </Border>
                            </VerticalStackLayout>
                            <Button Text="Save Changes"
                                    Command="{Binding SaveEditCommand}"
                                    HeightRequest="48" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- QR Code Section -->
                <Border Style="{StaticResource Card}"
                        Margin="20,16,20,0"
                        Padding="20">
                    <VerticalStackLayout Spacing="14" HorizontalOptions="Center">
                        <Label Text="Ticket QR Code"
                               Style="{StaticResource Subheadline}"
                               HorizontalOptions="Center" />
                        <Image Source="{Binding QrCodeImage}"
                               WidthRequest="180" HeightRequest="180"
                               HorizontalOptions="Center" />
                        <Label Text="Present this QR at the entrance"
                               Style="{StaticResource Caption}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Action Buttons -->
                <Border Style="{StaticResource Card}"
                        Margin="20,16,20,0"
                        Padding="16">
                    <VerticalStackLayout Spacing="10">
                        <Button Text="Share Ticket"
                                Style="{StaticResource ButtonSecondary}"
                                Command="{Binding ShareTicketCommand}"
                                HeightRequest="48" />
                        <Button Text="Save to Gallery"
                                Style="{StaticResource ButtonSecondary}"
                                Command="{Binding SaveToGalleryCommand}"
                                HeightRequest="48" />
                        <Button Text="Regenerate QR Code"
                                Style="{StaticResource ButtonOutline}"
                                Command="{Binding RegenerateTicketCommand}"
                                HeightRequest="48" />
                        <Button Text="Delete Participant"
                                Style="{StaticResource ButtonDanger}"
                                Command="{Binding DeleteAttendeeCommand}"
                                HeightRequest="48"
                                Margin="0,4,0,0" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

</ContentPage>
