<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Ticket.ViewModels"
             x:Class="Ticket.Views.ParticipantDetailPage"
             x:DataType="vm:ParticipantDetailViewModel"
             Title="Participant"
             BackgroundColor="{StaticResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="20">
            <Border StrokeShape="RoundRectangle 12"
                    Stroke="{StaticResource Gray200}"
                    BackgroundColor="{StaticResource CardBackground}"
                    Padding="24"
                    Shadow="{StaticResource CardShadow}">
                <VerticalStackLayout Spacing="12">
                    <Border WidthRequest="100" HeightRequest="100"
                            StrokeShape="RoundRectangle 50"
                            Stroke="{StaticResource Gray200}"
                            BackgroundColor="{StaticResource Gray100}"
                            HorizontalOptions="Center"
                            IsVisible="{Binding AttendeePhoto, Converter={StaticResource IsNotNullConverter}}">
                        <Image Source="{Binding AttendeePhoto}"
                               Aspect="AspectFill"
                               WidthRequest="100"
                               HeightRequest="100" />
                    </Border>

                    <Label Text="{Binding Attendee.FullName}"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"
                           HorizontalOptions="Center" />

                    <Label Text="{Binding Attendee.TicketCode}"
                           FontSize="14"
                           TextColor="{StaticResource Gray500}"
                           HorizontalOptions="Center" />

                    <BoxView HeightRequest="1" Color="{StaticResource Gray200}" />

                    <Image Source="{Binding QrCodeImage}"
                           WidthRequest="180"
                           HeightRequest="180"
                           HorizontalOptions="Center" />

                    <BoxView HeightRequest="1" Color="{StaticResource Gray200}" />

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="8">
                        <Label Text="Phone" FontSize="12" TextColor="{StaticResource Gray500}"
                               Grid.Row="0" Grid.Column="0" />
                        <Label Text="{Binding Attendee.PhoneNumber}" FontSize="16"
                               TextColor="{StaticResource TextPrimary}"
                               Grid.Row="0" Grid.Column="1" />

                        <Label Text="Type" FontSize="12" TextColor="{StaticResource Gray500}"
                               Grid.Row="1" Grid.Column="0" />
                        <Label Text="{Binding Attendee.TicketType}" FontSize="16"
                               TextColor="{StaticResource TextPrimary}"
                               Grid.Row="1" Grid.Column="1" />

                        <Label Text="Status" FontSize="12" TextColor="{StaticResource Gray500}"
                               Grid.Row="2" Grid.Column="0" />
                        <Label Text="{Binding Attendee.PaymentStatus}" FontSize="16"
                               TextColor="{StaticResource Success}"
                               Grid.Row="2" Grid.Column="1" />

                        <Label Text="Check-in" FontSize="12" TextColor="{StaticResource Gray500}"
                               Grid.Row="3" Grid.Column="0" />
                        <Label Text="{Binding Attendee.CheckedInAt, StringFormat='{0:MMM dd, HH:mm}'}"
                               FontSize="16"
                               TextColor="{StaticResource TextPrimary}"
                               Grid.Row="3" Grid.Column="1" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border StrokeShape="RoundRectangle 12"
                    BackgroundColor="#10B981"
                    HeightRequest="50"
                    Padding="16">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SaveToGalleryCommand}" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="8" VerticalOptions="Center" HorizontalOptions="Center">
                    <Label Text="&#xf0c7;" FontFamily="FAS" TextColor="White" FontSize="18" VerticalOptions="Center" />
                    <Label Text="Save to Gallery" TextColor="White" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>

            <Border StrokeShape="RoundRectangle 12"
                    BackgroundColor="{StaticResource Accent}"
                    HeightRequest="50"
                    Padding="16">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ShareTicketCommand}" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="8" VerticalOptions="Center" HorizontalOptions="Center">
                    <Label Text="&#xf1e0;" FontFamily="FAS" TextColor="White" FontSize="18" VerticalOptions="Center" />
                    <Label Text="Share Ticket" TextColor="White" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>

            <Border StrokeShape="RoundRectangle 12"
                    BackgroundColor="{StaticResource Warning}"
                    HeightRequest="50"
                    Padding="16">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding RegenerateTicketCommand}" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="8" VerticalOptions="Center" HorizontalOptions="Center">
                    <Label Text="&#xf021;" FontFamily="FAS" TextColor="White" FontSize="18" VerticalOptions="Center" />
                    <Label Text="Regenerate Ticket" TextColor="White" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>

            <Border StrokeShape="RoundRectangle 12"
                    BackgroundColor="#EF4444"
                    HeightRequest="50"
                    Padding="16">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding DeleteAttendeeCommand}" />
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="8" VerticalOptions="Center" HorizontalOptions="Center">
                    <Label Text="&#xf2ed;" FontFamily="FAS" TextColor="White" FontSize="18" VerticalOptions="Center" />
                    <Label Text="Delete Participant" TextColor="White" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{StaticResource Primary}" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
