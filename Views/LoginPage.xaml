<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Ticket.ViewModels"
             x:Class="Ticket.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource DarkPageBackground}}">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Hero Section -->
            <Grid BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark=#1A1B3E}"
                  Padding="32,60,32,40">
                <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                    <!-- App icon -->
                    <Border BackgroundColor="#30FFFFFF"
                            StrokeShape="RoundRectangle 20"
                            StrokeThickness="0"
                            WidthRequest="72" HeightRequest="72"
                            HorizontalOptions="Center">
                        <Image Source="eventpro"
                               Aspect="AspectFit"
                               WidthRequest="100" HeightRequest="100"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>

                    <Label Text="EventPro"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center" />

                    <Label Text="Event Management &amp; Ticketing"
                           FontSize="14"
                           TextColor="#D0D5FF"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Grid>

            <!-- Login Form Card (overlapping) -->
            <Border Style="{StaticResource CardFloating}"
                    Margin="20,-24,20,0"
                    Padding="24">
                <VerticalStackLayout Spacing="20">

                    <Label Text="Welcome back"
                           Style="{StaticResource Headline}" />
                    <Label Text="Sign in to manage your event"
                           Style="{StaticResource BodySmall}" />

                    <!-- Error Message -->
                    <Border IsVisible="{Binding HasError}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource DangerLight}, Dark=#3D1A1A}"
                            StrokeShape="RoundRectangle 10"
                            StrokeThickness="0"
                            Padding="14,10">
                        <Label Text="{Binding ErrorMessage}"
                               TextColor="{StaticResource Danger}"
                               FontSize="13"
                               HorizontalTextAlignment="Center" />
                    </Border>

                    <!-- Email -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Email" Style="{StaticResource FormLabel}" />
                        <Border Style="{StaticResource FormField}">
                            <Entry Placeholder="Enter your email"
                                   Keyboard="Email"
                                   Text="{Binding Email}"
                                   ReturnType="Next" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Password -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Password" Style="{StaticResource FormLabel}" />
                        <Border Style="{StaticResource FormField}">
                            <Entry Placeholder="Enter your password"
                                   IsPassword="True"
                                   Text="{Binding Password}"
                                   ReturnType="Done" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Remember Me -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Switch IsToggled="{Binding RememberMe}"
                                OnColor="{StaticResource Primary}" />
                        <Label Grid.Column="1"
                               Text="Remember me"
                               Style="{StaticResource BodySmall}"
                               VerticalOptions="Center" />
                    </Grid>

                    <!-- Login Button -->
                    <Button Text="Sign In"
                            Command="{Binding LoginCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                            HeightRequest="52"
                            FontSize="16"
                            Margin="0,4,0,0" />

                    <!-- Loading -->
                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       HorizontalOptions="Center" />

                </VerticalStackLayout>
            </Border>

            <!-- Footer -->
            <Label Text="EventPro by Eddy Graphix"
                   FontSize="12"
                   TextColor="{AppThemeBinding Light={StaticResource TextTertiary}, Dark={StaticResource DarkTextTertiary}}"
                   HorizontalOptions="Center"
                   Margin="0,24,0,32" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
