<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Ticket.ViewModels"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="Ticket.Views.TicketPreviewPage"
             x:DataType="vm:TicketPreviewViewModel"
             Title="Ticket"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource DarkPageBackground}}">

    <Grid RowDefinitions="*,Auto">
        <!-- Ticket Image -->
        <ScrollView>
            <VerticalStackLayout Spacing="0" Padding="20,16">
                <!-- Header -->
                <Label Text="Your Ticket"
                       Style="{StaticResource DisplayMedium}"
                       Margin="0,0,0,4" />
                <Label Text="Share or save to gallery"
                       Style="{StaticResource BodySmall}"
                       Margin="0,0,0,20" />

                <!-- Loading indicator -->
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   HeightRequest="40"
                                   Margin="0,60,0,60" />

                <!-- Ticket Image -->
                <Border Style="{StaticResource Card}"
                        Padding="8"
                        IsVisible="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}">
                    <Image Source="{Binding TicketImage}"
                           Aspect="AspectFit"
                           HorizontalOptions="Center" />
                </Border>

                <!-- Share/Save buttons -->
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12"
                      Margin="0,20,0,0"
                      IsVisible="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}">
                    <Button Text="&#xf1e0;  Share"
                            Style="{StaticResource ButtonSecondary}"
                            Command="{Binding ShareTicketCommand}"
                            HeightRequest="50"
                            FontSize="14" />
                    <Button Grid.Column="1"
                            Text="&#xf0a0;  Save"
                            Style="{StaticResource ButtonSecondary}"
                            Command="{Binding SaveToGalleryCommand}"
                            HeightRequest="50"
                            FontSize="14" />
                </Grid>

                <!-- Saved confirmation -->
                <Border BackgroundColor="{AppThemeBinding Light={StaticResource SuccessLight}, Dark=#0A2E1A}"
                        StrokeShape="RoundRectangle 10"
                        StrokeThickness="0"
                        Padding="14,10"
                        Margin="0,12,0,0"
                        IsVisible="{Binding SaveDone}">
                    <Label Text="&#xf00c;  Saved to gallery!"
                           FontFamily="FAS"
                           FontSize="13"
                           TextColor="{StaticResource Success}"
                           HorizontalTextAlignment="Center" />
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Done button -->
        <Border Grid.Row="1"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource DarkCardBackground}}"
                Padding="20,12,20,28">
            <Button Text="Done"
                    Command="{Binding DoneCommand}"
                    Style="{StaticResource ButtonOutline}"
                    HeightRequest="50" />
        </Border>
    </Grid>

</ContentPage>
