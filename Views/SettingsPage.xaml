<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Ticket.ViewModels"
             x:Class="Ticket.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="Settings"
             BackgroundColor="{AppThemeBinding Light={StaticResource PageBackground}, Dark={StaticResource DarkPageBackground}}">

    <RefreshView Command="{Binding LoadSettingsCommand}"
                 IsRefreshing="{Binding IsBusy}">
        <ScrollView>
            <VerticalStackLayout Spacing="0" Padding="20,16">

                <!-- Header -->
                <Label Text="Settings"
                       Style="{StaticResource DisplayMedium}"
                       Margin="0,0,0,20" />

                <!-- Event Details Section -->
                <Label Text="Event Details"
                       Style="{StaticResource Eyebrow}"
                       Margin="0,0,0,10" />
                <Border Style="{StaticResource SectionCard}" Padding="20" Margin="0,0,0,16">
                    <VerticalStackLayout Spacing="18">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Event Name" Style="{StaticResource FormLabel}" />
                            <Border Style="{StaticResource FormField}">
                                <Entry Placeholder="Event name"
                                       Text="{Binding EventName}"
                                       IsReadOnly="{Binding IsAdmin, Converter={StaticResource InverseBoolConverter}}" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Event Date" Style="{StaticResource FormLabel}" />
                            <Border Style="{StaticResource FormField}" Padding="16,0">
                                <DatePicker Date="{Binding EventDate}" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Venue" Style="{StaticResource FormLabel}" />
                            <Border Style="{StaticResource FormField}">
                                <Entry Placeholder="Venue name"
                                       Text="{Binding Venue}"
                                       IsReadOnly="{Binding IsAdmin, Converter={StaticResource InverseBoolConverter}}" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Description" Style="{StaticResource FormLabel}" />
                            <Border Style="{StaticResource FormField}"
                                    HeightRequest="100"
                                    Padding="16,8">
                                <Editor Placeholder="Event description..."
                                        Text="{Binding Description}"
                                        HeightRequest="84"
                                        IsReadOnly="{Binding IsAdmin, Converter={StaticResource InverseBoolConverter}}" />
                            </Border>
                        </VerticalStackLayout>

                        <Button Text="Save Settings"
                                Command="{Binding SaveEventCommand}"
                                IsVisible="{Binding IsAdmin}"
                                HeightRequest="48"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />

                        <Label Text="Only administrators can modify event settings"
                               Style="{StaticResource Caption}"
                               IsVisible="{Binding IsAdmin, Converter={StaticResource InverseBoolConverter}}"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Account Section -->
                <Label Text="Account"
                       Style="{StaticResource Eyebrow}"
                       Margin="0,0,0,10" />
                <Border Style="{StaticResource Card}" Padding="20" Margin="0,0,0,16">
                    <VerticalStackLayout Spacing="16">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource PrimaryContainer}, Dark={StaticResource DarkSurfaceTertiary}}"
                                    StrokeShape="RoundRectangle 10"
                                    StrokeThickness="0"
                                    WidthRequest="44" HeightRequest="44">
                                <Label Text="&#xf007;"
                                       FontFamily="FAS"
                                       FontSize="20"
                                       TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource Secondary}}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="Role"
                                       Style="{StaticResource Caption}" />
                                <Label Text="Admin"
                                       Style="{StaticResource BodySmall}"
                                       IsVisible="{Binding IsAdmin}" />
                                <Label Text="Operator"
                                       Style="{StaticResource BodySmall}"
                                       IsVisible="{Binding IsAdmin, Converter={StaticResource InverseBoolConverter}}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="&#xf054;"
                                   FontFamily="FAS"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light={StaticResource TextTertiary}, Dark={StaticResource DarkTextTertiary}}"
                                   VerticalOptions="Center" />
                        </Grid>

                        <BoxView Style="{StaticResource Divider}" />

                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                            <Border BackgroundColor="{AppThemeBinding Light={StaticResource InfoLight}, Dark=#0A2E4A}"
                                    StrokeShape="RoundRectangle 10"
                                    StrokeThickness="0"
                                    WidthRequest="44" HeightRequest="44">
                                <Label Text="&#xf1cd;"
                                       FontFamily="FAS"
                                       FontSize="20"
                                       TextColor="{StaticResource Info}"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="Version"
                                       Style="{StaticResource Caption}" />
                                <Label Text="{Binding AppVersion}"
                                       Style="{StaticResource BodySmall}" />
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Logout -->
                <Button Text="Logout"
                        Style="{StaticResource ButtonOutline}"
                        Command="{Binding LogoutCommand}"
                        TextColor="{StaticResource Danger}"
                        BorderColor="{StaticResource Danger}"
                        Margin="0,8,0,32" />

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

</ContentPage>
